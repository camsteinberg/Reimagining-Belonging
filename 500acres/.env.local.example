# ─── Database ───────────────────────────────────
DATABASE_URL=                    # Neon PostgreSQL connection string

# ─── Auth ───────────────────────────────────────
AUTH_SECRET=                     # JWT signing secret (generate with: openssl rand -base64 32)

# ─── Maps ───────────────────────────────────────
NEXT_PUBLIC_MAPBOX_TOKEN=        # Mapbox GL access token (public, client-side)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY= # Google Maps API key (realestate dashboard)

# ─── Email ──────────────────────────────────────
RESEND_API_KEY=                  # Resend transactional email API key
EMAIL_FROM=                      # From address (default: 500 Acres <noreply@habitable.us>)

# ─── Google Sheets ──────────────────────────────
GOOGLE_SERVICE_ACCOUNT_EMAIL=    # Google service account email
GOOGLE_PRIVATE_KEY=              # Google service account private key (with \n for newlines)
GOOGLE_SHEET_ID=                 # Primary Google Sheet ID (buzz data)
GOOGLE_SHEET_RANGE=              # Sheet range for primary data

# ─── Sheet IDs (Dashboard Data Sources) ─────────
GOVERNANCE_SHEET_ID=             # Governance data sheet
CONTACTS_ID=                     # Contacts sheet
TOPQ_SHEET_ID=                   # TOPQ data sheet
BARNDOS_SHEET_ID=                # Barndos real estate sheet
TILL_FILE_IDS=                   # Comma-separated Google Drive file IDs for Till XLSX data

# ─── App ────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=            # Public site URL (default: https://habitable.us)
MONEY_TEAM_EMAILS=               # Comma-separated admin notification emails
DEFAULT_PHONE_REGION=            # Phone number region (default: US)
